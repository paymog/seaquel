{
  "name": "seaquel",
  "version": "2026.4.8-beta.1",
  "description": "Explore, query, and visualize your databases — all in one app.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:demo": "BUILD_TARGET=demo vite build --mode demo",
    "format": "oxfmt",
    "lint": "oxlint --type-aware --type-check --deny-warnings --fix",
    "preview": "vite preview",
    "preview:demo": "vite preview --outDir build-demo",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config '{\"identifier\":\"app.seaquel.desktop.dev\"}'",
    "e2e:db:sqlite": "node e2e/test-databases/sqlite/create-test-db.mjs",
    "demos:db:create": "rm -f docs/demos.db && sqlite3 docs/demos.db < docs/sample-data.sql",
    "demos:start": "SEAQUEL_DATA_DIR=~/projects/github/webstonehq/seaquel/docs/data tauri dev --config '{\"identifier\":\"app.seaquel.desktop.dev\"}'",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@duckdb/duckdb-wasm": "^1.32.0",
    "@tanstack/svelte-virtual": "^3.13.13",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xyflow/svelte": "^1.5.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "diff-match-patch": "^1.0.5",
    "html-to-image": "^1.11.13",
    "layerchart": "^2.0.0-next.44",
    "marked": "^17.0.5",
    "monaco-editor": "^0.55.1",
    "monaco-emacs": "^0.3.0",
    "monaco-sql-languages": "^0.15.1",
    "monaco-vim": "^0.4.4",
    "node-sql-parser": "^5.4.0",
    "sql-formatter": "^15.6.12",
    "sql.js": "^1.14.1",
    "svelte-dnd-action": "^0.9.69",
    "tauri-plugin-keyring-api": "^0.1.1"
  },
  "devDependencies": {
    "@duckdb/node-api": "^1.4.4-r.3",
    "@faker-js/faker": "^10.3.0",
    "@inlang/paraglide-js": "^2.6.0",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dagre": "^0.7.53",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^25.0.3",
    "better-sqlite3": "^12.5.0",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "lefthook": "^2.1.2",
    "mode-watcher": "^1.1.0",
    "mysql2": "^3.18.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "paneforge": "^1.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
